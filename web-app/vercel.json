{
    "version": 2,
    "public": true,
    "cleanUrls": true,
    "builds": [
        {
            "src": "dist/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/assets/(.*)",
            "destination": "/dist/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/dist/index.html"
        }
    ]
}